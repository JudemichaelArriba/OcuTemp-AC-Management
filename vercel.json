{
  "buildCommand": "node set-env.js && ng build",
  "outputDirectory": "dist/Ocutemp",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "font-src 'self' https://*.vercel-storage.com https://*.vercel.com https://fonts.gstatic.com https://vercel.live;"
        }
      ]
    }
  ]
}