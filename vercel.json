{
  "buildCommand": "node set-env.js && ng build",
  "outputDirectory": "dist/Ocutemp/browser",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "font-src 'self' *.vercel.com *.vercel-storage.com *.gstatic.com vercel.live fonts.gstatic.com"
        }
      ]
    }
  ]
}